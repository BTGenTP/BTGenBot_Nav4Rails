# No secrets in this file. Copy locally if needed and keep real values out of git.
NAV4RAIL_GRAPHRAG_PROFILE=local
NAV4RAIL_GRAPHRAG_DATASET_PATH=../dataset/bt_dataset.json
NAV4RAIL_GRAPHRAG_ARTIFACT_DIR=artifacts
NAV4RAIL_GRAPHRAG_LLM_PROVIDER=echo
NAV4RAIL_GRAPHRAG_LLM_MODEL=echo/offline
NAV4RAIL_GRAPHRAG_LLM_TEMPERATURE=0.0
NAV4RAIL_GRAPHRAG_LLM_MAX_TOKENS=2048
NAV4RAIL_GRAPHRAG_RETRIEVAL_TOP_K=5
NAV4RAIL_GRAPHRAG_REPAIR_MAX_ATTEMPTS=1
NAV4RAIL_GRAPHRAG_LOG_JSON=false
NAV4RAIL_GRAPHRAG_TRACE=false

# Online inference examples. Keep real keys in your shell or secret manager.
# NAV4RAIL_GRAPHRAG_LLM_PROVIDER=mistral
# NAV4RAIL_GRAPHRAG_LLM_MODEL=mistral/mistral-large-latest
# MISTRAL_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Optional W&B tracking.
NAV4RAIL_GRAPHRAG_WANDB_ENABLED=false
NAV4RAIL_GRAPHRAG_WANDB_PROJECT=nav4rail-graphrag
NAV4RAIL_GRAPHRAG_WANDB_ENTITY=
NAV4RAIL_GRAPHRAG_WANDB_GROUP=
NAV4RAIL_GRAPHRAG_WANDB_TAGS=mvp,graphrag
NAV4RAIL_GRAPHRAG_WANDB_MODE=
